NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ── Xero OAuth (Payroll AU) ──────────────────────────────────────────────
XERO_CLIENT_ID=YOUR-XERO-CLIENT-ID
XERO_CLIENT_SECRET=YOUR-XERO-CLIENT-SECRET
XERO_REDIRECT_URI=http://localhost:3001/api/xero/callback
XERO_SCOPES=openid profile email offline_access accounting.contacts payroll.employees payroll.payruns payroll.payslip payroll.timesheets payroll.settings
