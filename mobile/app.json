{
  "expo": {
    "name": "Timevera",
    "slug": "timevera-timesheets",
    "version": "0.1.0",
    "scheme": "timevera",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/timevera-icon.png",
    "splash": {
      "image": "./assets/timevera-icon.png",
      "backgroundColor": "#F4F4F5",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.timevera.timesheets",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Timevera uses Face ID to securely unlock the app and sign you in.",
        "NSCameraUsageDescription": "Timevera uses the camera to take a photo when you clock in, verifying your attendance on site.",
        "NSPhotoLibraryUsageDescription": "Timevera lets you choose a photo from your library to set your profile picture.",
        "NSLocationWhenInUseUsageDescription": "Timevera records your location when you clock in to confirm you are on the job site.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.timevera.timesheets",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/timevera-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#1C1A16"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6f6a8036-a2bb-4b86-89d2-4600b1f8b04f"
      }
    },
    "owner": "flixxy"
  }
}
