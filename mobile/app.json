{
  "expo": {
    "name": "BuildOne",
    "slug": "buildone-timesheets",
    "version": "0.1.0",
    "scheme": "buildone",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/buildone.png",
      "backgroundColor": "#F6F4EF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buildone.timesheets",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in to your timesheet."
      }
    },
    "android": {
      "package": "com.buildone.timesheets",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C1A16"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#9A7A4E"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
