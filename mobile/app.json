{
  "expo": {
    "name": "Build One Timesheets",
    "slug": "buildone-timesheets",
    "version": "0.1.0",
    "scheme": "buildone",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#9A7A4E",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.buildone.timesheets",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in to your timesheet."
      }
    },
    "android": {
      "package": "com.buildone.timesheets"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "color": "#9A7A4E"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
